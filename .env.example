# =============================================
# E-Doctor Platform — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database (PHP / MySQL) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=edoc_platform

# --- Node.js Backend ---
NODE_PORT=5000
NODE_DB_HOST=localhost
NODE_DB_USER=root
NODE_DB_PASSWORD=your_password_here
NODE_DB_NAME=edoc_platform

# --- App ---
APP_ENV=development
APP_URL=http://localhost
